<!-- Keep in sync with nix/home-manager-module.nix (launchd.agents.gitsitter) -->
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.gitsitter.daemon</string>
    <key>ProgramArguments</key>
    <array>
        <string>@@EXEC_PATH@@</string>
        <string>daemon</string>
        <string>run</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>StandardOutPath</key>
    <string>@@LOG_DIR@@/gitsitter.out.log</string>
    <key>StandardErrorPath</key>
    <string>@@LOG_DIR@@/gitsitter.err.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>@@DAEMON_PATH@@</string>
    </dict>
</dict>
</plist>
